# AutoStock 環境變數範本
# 複製此檔案為 .env 並填入實際值

# ============================================================
# 必填項目
# ============================================================

# 資料庫連線（Railway 會自動提供）
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT 密鑰（請使用隨機長字串）
JWT_SECRET_KEY=your-random-secret-key-at-least-32-chars

# LINE Login（從 LINE Developers Console 取得）
LINE_LOGIN_CHANNEL_ID=your-channel-id
LINE_LOGIN_CHANNEL_SECRET=your-channel-secret
LINE_LOGIN_CALLBACK_URL=https://your-domain.railway.app/auth/line/callback

# 環境設定
APP_ENV=production

# ============================================================
# 選填項目
# ============================================================

# LINE 推播（用於通知功能）
# LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token

# Debug 模式（正式環境請設為 False）
# DEBUG=False
